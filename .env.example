# Скопируйте этот файл в .env и заполните под себя:
#     cp .env.example .env
#
# .env в репозиторий не попадает (см. .gitignore) — в нём номер вашей заявки.
# Константы протокола ЕПГУ (адреса ручек, идентификаторы услуг) сюда не выносятся,
# они в src/gswatch/constants.py.


# ─── Обязательное ─────────────────────────────────────────────────────────────

# Номер заявки на загранпаспорт — он же parentOrderId, 10 цифр.
# Где взять: откройте заявление в личном кабинете и нажмите «Записаться на приём»;
# номер будет в адресе страницы, ...booking?parentOrderId=XXXXXXXXXX
# Он же уходит в заголовке X-Order-Id.
GSWATCH_ORDER_ID=

# Отделения, за которыми следить: коды CODE_FRGU через запятую, без пробелов.
# Это то же самое, что organizationId в теле запроса слотов.
# Где взять: в ответе POST /api/service/booking, поле applicantAnswers.ms1 →
# attributeValues.CODE_FRGU — это отделение, выбранное вами в заявлении.
# Если рядом лежит справочник offices_moscow.json (в репозиторий не входит,
# см. README), код можно найти в нём по адресу отделения.
#
# Осторожно: подача обычно привязана к прописке, так что слот в чужом отделении
# может оказаться бесполезным. Сначала выясните, куда вы вправе подать.
#
# Учтите, что по одному адресу могут сидеть два разных отдела — тогда это два
# разных кода, и следить надо за обоими.
#
# Формат: GSWATCH_OFFICES=<код>,<код>,<код>
GSWATCH_OFFICES=


# ─── Услуга ───────────────────────────────────────────────────────────────────

# Какой именно загранпаспорт. Определяет serviceId в запросе (см. constants.py).
# Допустимые значения:
#   new_adult        нового образца (биометрический, 10 лет), заявитель 18+
#   new_child        нового образца, на ребёнка до 18 лет
#   old_adult        старого образца (5 лет), заявитель 18+
#   old_child_ai18   старого образца на ребёнка, заполнен блок ai18
#   old_child_ai19   старого образца на ребёнка, заполнен блок ai19
GSWATCH_PASSPORT_TYPE=new_adult


# ─── Частота опроса ───────────────────────────────────────────────────────────

# Базовый период между полными обходами всех отделений, в минутах.
# Ниже 5 опускать не стоит: слоты так часто не появляются, а нагрузка и
# заметность растут.
GSWATCH_PERIOD_MIN=8

# Случайный разброс периода в минутах: пауза = PERIOD ± JITTER.
# Нужен, чтобы интервалы не были машинно-ровными. Должен быть меньше PERIOD.
GSWATCH_JITTER_MIN=5

# Пока слоты в отделении не пропадали, не повторять алерт по нему чаще, чем
# раз в столько минут. Иначе одни и те же слоты будут звонить каждый цикл.
GSWATCH_REPEAT_ALERT_MIN=20

# Пауза между отделениями внутри одного обхода, секунды: случайная величина
# из этого диапазона. Нужна, чтобы запросы уходили вразбивку, а не пачкой.
GSWATCH_OFFICE_PAUSE_MIN_SEC=1
GSWATCH_OFFICE_PAUSE_MAX_SEC=4

# Сколько слотов перечислять в уведомлении. Остальные сворачиваются в
# «… и ещё N»: при полусотне свободных мест список бесполезен.
GSWATCH_SLOTS_IN_MESSAGE=10


# ─── Какие каналы включены ────────────────────────────────────────────────────

# Рубильники: выключают канал, не стирая его настройки. Номер телефона и токен
# бота можно оставить заполненными на будущее, а сам канал погасить.
#
# Канал работает, только если он включён здесь И заполнены его параметры ниже.
# При запуске сторож пишет по каждому каналу, включён он, выключен настройкой
# или не настроен — так видно, почему он молчит.
#
# Лога в списке нет: он включён всегда, иначе при отвале остальных каналов
# сторож работал бы вслепую.

GSWATCH_ALERT_MAC=true        # звук, голос, окно на самом Маке
GSWATCH_ALERT_MESSAGES=true   # SMS или iMessage на телефон
GSWATCH_ALERT_TELEGRAM=true   # бот в Telegram
GSWATCH_ALERT_VK=true         # ВКонтакте (всё равно молчит, пока не настроен)


# ─── Сигнал на самом Маке ─────────────────────────────────────────────────────

# Самый надёжный канал: сети не требует вовсе, блокировки и VPN ни при чём.
# Шумит только на появление слотов; запуск, ошибки и протухшая сессия проходят
# тихим уведомлением.

# Разбудить дисплей, если Мак спит.
GSWATCH_MAC_WAKE_SCREEN=true

# Выкрутить громкость перед сигналом — иначе при тихой системе всё зря.
# Прежнее значение возвращается, когда сигнал отзвучит.
GSWATCH_MAC_MAX_VOLUME=true
GSWATCH_MAC_VOLUME_LEVEL=100

# Голос, которым проговорить, где и сколько слотов. Пусто — не говорить.
# Список доступных: say -v '?'
GSWATCH_MAC_VOICE=Milena

# Звук из /System/Library/Sounds и сколько раз повторить. Пусто — не пищать.
# Доступны: Basso, Blow, Bottle, Frog, Funk, Glass, Hero, Morse, Ping, Pop,
# Purr, Sosumi, Submarine, Tink
GSWATCH_MAC_SOUND=Sosumi
GSWATCH_MAC_SOUND_REPEAT=5

# Модальное окно с кнопкой «Понял». Нажатие обрывает звук досрочно.
GSWATCH_MAC_MODAL=true


# ─── Messages.app: SMS или iMessage (необязательно) ───────────────────────────

# Сообщение на телефон мимо Telegram, бесплатно.
# Укажите номер (+7...) или Apple ID; пусто — канал выключен.
# Messages.app должен быть запущен и залогинен. При первой отправке macOS
# спросит разрешение на автоматизацию — без него будет ошибка -1743.
GSWATCH_MESSAGES_TO=

# Какой службой слать. Откатов нет: что указано, тем и отправляется — если
# просить iMessage для номера, которого в нём нет, сообщение просто повиснет
# красным «Not Delivered».
#   SMS       уходит через iPhone по «Пересылке SMS» и приходит настоящим
#             входящим — со звуком и баннером. Доходит даже без интернета
#             на телефоне. Требует: Настройки → Сообщения → Пересылка SMS.
#   iMessage  только если номер зарегистрирован в iMessage. При отправке
#             самому себе синхронизируется как исходящее — может прийти молча.
GSWATCH_MESSAGES_SERVICE=SMS


# ─── Telegram (необязательно) ─────────────────────────────────────────────────

# Если обе переменные пусты, Telegram просто не подключается и всё идёт в лог.
# Заполнять надо ОБЕ — при одной заполненной скрипт откажется стартовать, чтобы
# вы не думали, что уведомления настроены, когда это не так.

# Токен бота от @BotFather, вид 123456789:AAH...
# Это пароль от бота: держите его только в .env, он в репозиторий не попадает.
GSWATCH_TG_TOKEN=

# Куда слать. Ваш личный id можно узнать у @userinfobot.
# Важно: сначала напишите своему боту любое сообщение — Telegram запрещает
# ботам писать первыми, иначе будет ошибка "chat not found".
GSWATCH_TG_CHAT_ID=


# ─── ВКонтакте (необязательно) ────────────────────────────────────────────────

# Российский сервис — блокировки его не касаются, в отличие от Telegram.
# Нужны сообщество с ботом, ключ доступа с правом «Сообщения» и ваш числовой id.
# Порядок настройки по шагам — в комментарии к src/gswatch/alerts/vk.py.
# Как и в Telegram, сначала напишите сообществу со своей страницы: писать вам
# первым оно не имеет права.
GSWATCH_VK_TOKEN=
GSWATCH_VK_PEER_ID=


# ─── Прочее ───────────────────────────────────────────────────────────────────

# Каталог с профилем Chrome, в котором живёт сессия Госуслуг.
# Держите его вне репозитория: там куки от вашего аккаунта.
#
# Указывайте ОТДЕЛЬНЫЙ каталог, а не свой основной профиль Chrome
# (~/Library/Application Support/Google/Chrome). Playwright откроет ровно тот
# профиль, который здесь задан, — со всеми вашими вкладками, паролями и куками
# всех сайтов. Отдельный профиль означает и отдельный вход в Госуслуги: один
# раз руками, дальше сессия живёт сама.
GSWATCH_PROFILE_DIR=~/.gswatch/chrome-profile
